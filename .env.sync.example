# Copy this file to .env.sync and fill in your values.
# .env.sync is gitignored — never commit it.

PODCAST_MANAGER_URL=http://192.168.1.100:8841   # podcast-manager (Flask app)
PODCAST_FEED_URL=http://192.168.1.100:8840/feed.xml  # nginx RSS feed

# Optional: override Apple Podcasts DB path (default works on macOS)
# APPLE_PODCASTS_DB=/path/to/MTLibrary.sqlite
