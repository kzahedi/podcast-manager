# Copy this file to .env.deploy and fill in your values.
# .env.deploy is gitignored — never commit it.

DEPLOY_HOST=192.168.1.100     # IP or hostname of your Synology NAS
DEPLOY_USER=admin             # SSH user on the NAS
DEPLOY_PATH=/volume1/docker/podcast-manager  # Path where docker-compose.yml lives on the NAS
DEPLOY_PORT=22                # SSH port (default: 22)

# Optional overrides
# IMAGE_NAME=podcast-manager
# COMPOSE_SERVICE=podcast-manager
